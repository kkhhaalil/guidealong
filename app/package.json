{
  "name": "guidealong-app",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "preview": "vite preview",
    "typecheck": "tsc --noEmit -p tsconfig.app.json",
    "lint": "eslint .",
    "test": "vitest run",
    "check:budgets": "node ../scripts/check_budgets.mjs",
    "check:contrast": "node ../scripts/check_contrast.mjs",
    "check:lighthouse": "node ../scripts/check_lighthouse.mjs",
    "check:recipe": "node ../scripts/check_recipe.mjs",
    "e2e": "npm run build && NODE_PATH=./node_modules playwright test",
    "icons": "node scripts/gen-icons.mjs"
  },
  "dependencies": {
    "@fontsource/alfa-slab-one": "^5.2.8",
    "@fontsource/source-sans-3": "^5.2.9",
    "@types/leaflet": "^1.9.21",
    "clsx": "^2.1.1",
    "leaflet": "^1.9.4",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "tailwind-merge": "^3.3.1",
    "vite-plugin-pwa": "^1.3.0",
    "workbox-core": "^7.4.1",
    "workbox-precaching": "^7.4.1",
    "workbox-routing": "^7.4.1",
    "workbox-strategies": "^7.4.1",
    "zod": "^4.4.3",
    "zustand": "^5.0.14"
  },
  "devDependencies": {
    "@axe-core/playwright": "^4.12.1",
    "@eslint/js": "^10.0.1",
    "@playwright/test": "^1.61.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@types/node": "^24.13.2",
    "@types/react": "^18.3.18",
    "@types/react-dom": "^18.3.5",
    "@vitejs/plugin-react": "^4.3.4",
    "@vitest/coverage-v8": "^4.1.9",
    "autoprefixer": "^10.5.2",
    "eslint": "^10.6.0",
    "eslint-plugin-react-hooks": "^7.1.1",
    "eslint-plugin-react-refresh": "^0.5.3",
    "globals": "^17.7.0",
    "jsdom": "^29.1.1",
    "lighthouse": "^12.8.2",
    "postcss": "^8.5.16",
    "tailwindcss": "^3.4.17",
    "typescript": "~6.0.2",
    "typescript-eslint": "^8.62.1",
    "vite": "^6.3.5",
    "vitest": "^4.1.9"
  }
}
